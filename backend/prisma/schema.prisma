generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  nomeExibicao String
  email        String?        @unique
  senhaHash    String
  foto         String?
  tokens       RefreshToken[]
  criadoEm    DateTime       @default(now())
  notes Note[]
  blocos Bloco[]
}

model Note {
  id          Int      @id @default(autoincrement())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  titulo      String
  tituloCapa  String   @default("")
  conteudo    String
  cor         String   @default("#ffffff")
  imagemCapa  String?
  clips       Int      @default(0)
  canvasX     Float    @default(0)
  canvasY     Float    @default(0)
  canvasOrdem Int      @default(0)
  criadoEm   DateTime @default(now())
}

model RefreshToken {
  id       String   @id @default(uuid())
  token    String   @unique
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  revogado Boolean  @default(false)
  expiraEm DateTime
  criadoEm DateTime @default(now())
}

model Bloco {
  id           Int      @id @default(autoincrement())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome         String
  cardIds      Int[]    @default([])
  canvasX      Float    @default(0)
  canvasY      Float    @default(0)
  canvasOrdem  Int      @default(0)
  criadoEm    DateTime @default(now())
}